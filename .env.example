APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=archivo_digital
POSTGRES_USER=archivo
POSTGRES_PASSWORD=archivo_dev_password
DATABASE_URL=postgresql://archivo:archivo_dev_password@postgres:5432/archivo_digital

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:5173,wails://wails.localhost

# Carpetas locales configurables por cada computadora.
# HOST_INPUT_ROOT: de donde se toman los PDFs/imagenes.
# HOST_STORAGE_ROOT: donde se guarda la copia organizada de los casos procesados.
HOST_INPUT_ROOT=./data/source
HOST_STORAGE_ROOT=./data/storage

# Estos valores tambien se pueden configurar desde la app de escritorio.
DEFAULT_PROVIDER=google
ENABLE_ANTHROPIC_FALLBACK=true
MIN_EXTRACTION_CONFIDENCE=0.82
MAX_RUN_BUDGET_USD=300

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OCR_PROVIDER=local
EMBEDDING_PROVIDER=local

# Gateway stateless (docker-compose.gateway.yml)
GATEWAY_TOKEN=
RATE_LIMIT=60/minute
